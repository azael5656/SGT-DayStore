# MongoDB
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=sgt_iot_user
MONGO_PASSWORD=sgt_iot_password_dev
MONGO_DB=sgt_iot

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# MQTT
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# JWT (RS256 - solo verificacion)
# backend-iot NO firma tokens, solo verifica los que recibe. Por eso solo
# necesita la llave publica.
JWT_PUBLIC_KEY_PATH=../infra/keys/jwt-public.pem

# Servicio
IOT_PORT=3002
