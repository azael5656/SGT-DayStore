# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=sgt_user
POSTGRES_PASSWORD=sgt_password_dev
POSTGRES_DB=sgt_daystore

# JWT (RS256 asimetrico)
# Cuando corres LOCAL (fuera de Docker), apunta a la ruta real del archivo
# dentro de infra/keys/. En Docker las rutas son /app/keys/*.pem.
JWT_PRIVATE_KEY_PATH=../infra/keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=../infra/keys/jwt-public.pem
JWT_ACCESS_EXPIRES=1h
JWT_REFRESH_EXPIRES=15d

# Servicio
NEGOCIO_PORT=3001
