# === PostgreSQL (backend-negocio) ===
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=sgt_user
POSTGRES_PASSWORD=sgt_password_dev
POSTGRES_DB=sgt_daystore

# === MongoDB (backend-iot) ===
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_USER=sgt_iot_user
MONGO_PASSWORD=sgt_iot_password_dev
MONGO_DB=sgt_iot

# === Redis (backend-iot) ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# === MQTT / Mosquitto ===
MQTT_BROKER_URL=mqtt://mosquitto:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# === JWT (RS256 asimetrico) ===
# Rutas a los archivos .pem generados con infra/scripts/generate-jwt-keys.sh.
# En contenedores Docker se montan en /app/keys/ como read-only.
# Backend-negocio lee las DOS; backend-iot solo lee la publica.
JWT_PRIVATE_KEY_PATH=/app/keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=/app/keys/jwt-public.pem
JWT_ACCESS_EXPIRES=1h
JWT_REFRESH_EXPIRES=15d

# === Puertos de servicios ===
NEGOCIO_PORT=3001
IOT_PORT=3002

# === Simulador de sensores (dev/demo sin ESP32) ===
MOCK_SENSORS=true

# === TypeORM: auto-sincronizar schema en dev (NO usar en prod) ===
TYPEORM_SYNC=true

# === Auditoria service-to-service (backend-iot -> backend-negocio) ===
# Token compartido para que backend-iot publique audit logs al endpoint
# /api/negocio/audit/internal sin necesidad de JWT de usuario.
INTERNAL_AUDIT_TOKEN=cambiar-en-prod-shared-internal-secret
